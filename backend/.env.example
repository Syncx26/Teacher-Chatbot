# === REQUIRED ===
# Anthropic — Claude Haiku (micro) + Sonnet (standard/deep) | console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google AI Studio — Gemini 2.0 Flash (fast tier) | aistudio.google.com/apikey  Free: 1,500 req/day
GOOGLE_API_KEY=AIza...

# Google Cloud — YouTube Data API v3 | console.cloud.google.com  Free: 10,000 units/day (100 searches)
YOUTUBE_API_KEY=AIza...

# Tavily Search — web research tool | tavily.com  Free: 1,000 searches/month
TAVILY_API_KEY=tvly-...

# === RECOMMENDED ===
# Hugging Face — daily papers feed | huggingface.co/settings/tokens  Free
HF_TOKEN=hf_...

# Semantic Scholar — citation counts + paper discovery | semanticscholar.org/product/api  Free
SEMANTIC_SCHOLAR_API_KEY=

# === OPTIONAL OVERRIDES ===
DB_PATH=./chatbot.db
MODEL_HAIKU=claude-haiku-4-5-20251001
MODEL_SONNET=claude-sonnet-4-6
MODEL_GEMINI=gemini-2.0-flash
MAX_TOKENS=2048
CURRICULUM_SPEC_PATH=../warroom-curriculum-spec.md
